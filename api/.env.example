# Hireloop — API environment variables
# Copy to .env and fill in real values — NEVER commit .env

# ── App settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
# SECRET_KEY and SERVICE_SECRET MUST be set to strong, unique random values in
# production. The API refuses to boot when ENVIRONMENT=production and either is
# left empty or equal to "change-me" (see config.Settings._enforce_production_secrets).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-a-32-char-random-string
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:3000,http://127.0.0.1:3000,https://hireloop1-app.vercel.app
# OAuth redirect targets (browser-reachable)
PUBLIC_API_URL=http://localhost:8000
PUBLIC_APP_URL=https://hireloop1-app.vercel.app
# Production Railway (project truthful-forgiveness, service hireloop1):
#   https://railway.com/project/7f42f8d6-2192-4a15-912e-3d79a1869885
#   PUBLIC_API_URL=https://hireloop1-production.up.railway.app
#   Deploy from api/: railway link -p 7f42f8d6-2192-4a15-912e-3d79a1869885 -s hireloop1
#   Smoke test: ./scripts/smoke_railway.sh
# Comma-separated markets enabled for job ingest + matching (default: IN,US,GB)
ENABLED_MARKETS=IN,US,GB

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # NOT the anon key

# ── OpenRouter (LLM) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Must be valid OpenRouter model IDs — see https://openrouter.ai/models
OPENROUTER_PRIMARY_MODEL=anthropic/claude-opus-4.7
OPENROUTER_FALLBACK_MODEL=anthropic/claude-haiku-4.5
# Free fallback used when OpenRouter returns 402 / low credits. `openrouter/free`
# routes to currently available free models and filters for requested features.
OPENROUTER_FREE_MODEL=openrouter/free
# Aarya chat is concise; high max_tokens can trigger 402 on low-credit accounts.
OPENROUTER_CHAT_MAX_TOKENS=700
OPENROUTER_LOW_CREDIT_MAX_TOKENS=256
# Opt-in: have Aarya write a personalised "why you fit" line per job on the
# match feed's first screen (one LLM call, top ~8 jobs). Needs OPENROUTER_API_KEY.
# Off by default; set true in production to enable. Degrades gracefully if the
# LLM is unavailable (keeps the rule-based explanation).
MATCH_RATIONALE_ENABLED=false

# Opt-in: when Aarya's job_search returns nothing, fire a background career-path
# scoped Apify scrape to warm the index. Off by default — it spends Apify credits.
AUTO_INGEST_ON_EMPTY_SEARCH=false

# ── Deepgram (STT + TTS) ──────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key
# Optional Aura voice model for server-side TTS (default: aura-asteria-en)
DEEPGRAM_TTS_MODEL=aura-asteria-en

# ── Super admin (internal) ────────────────────────────────────────────────────
# Admin access is granted ONLY by (a) users.role == 'admin' (set server-side via
# the audited super-admin endpoint or out-of-band) or (b) this operator-managed
# email allow-list. It is NEVER derived from a user-editable field.
#
# Bootstrap the first admin by putting your verified login email here
# (comma-separated for multiple). Requires Supabase "Confirm email" to be enabled
# so the address can't be claimed by an attacker.
# Alternatively, run once:  UPDATE public.users SET role='admin' WHERE email='you@hireloop.in';
SUPER_ADMIN_EMAILS=

# ── Apify (scraping) ──────────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_...
# Use Fantastic.jobs Career Site Job Listing API (India-only) in addition to LinkedIn
APIFY_ENABLE_CAREER_SITE_INGEST=true
# LinkedIn jobs actor (keep a no-cookie actor here to comply with R16)
APIFY_LINKEDIN_JOBS_ACTOR=bebity/linkedin-jobs-scraper
APIFY_CAREER_SITE_ACTOR=fantastic-jobs/career-site-job-listing-api
# No-cookie LinkedIn profile scraper for candidate onboarding (dev_fusion default).
APIFY_LINKEDIN_PROFILE_ACTOR=dev_fusion/linkedin-profile-scraper

# ── Fantastic.jobs actor filters (see Apify input schema) ───────────────────
# Time window: 1h | 24h | 7d | 6m (6m = backfill; no descriptionSearch with 6m)
FANTASTIC_JOBS_TIME_RANGE=24h
FANTASTIC_JOBS_CANDIDATE_TIME_RANGE=7d
FANTASTIC_JOBS_REMOVE_AGENCY=true
FANTASTIC_JOBS_RECRUITER_ONLY=false
FANTASTIC_JOBS_EXCLUDE_ATS_DUPLICATE=true
FANTASTIC_JOBS_POPULATE_AI_REMOTE=true
FANTASTIC_JOBS_REQUIRE_SALARY=false
FANTASTIC_JOBS_VISA_SPONSORSHIP_ONLY=false
FANTASTIC_JOBS_NO_DIRECT_APPLY=false
FANTASTIC_JOBS_DIRECT_APPLY_ONLY=false
FANTASTIC_JOBS_USE_DESCRIPTION_SEARCH_FOR_CANDIDATES=true
FANTASTIC_JOBS_MAX_DESCRIPTION_SEARCH_TERMS=3
# Comma-separated — prefix match with :* per Fantastic.jobs docs
FANTASTIC_JOBS_TITLE_EXCLUSIONS=Intern:*,Trainee:*,Apprentice:*
# FANTASTIC_JOBS_LOCATION_EXCLUSIONS=
# FANTASTIC_JOBS_AI_WORK_ARRANGEMENT=Remote OK,Remote Solely,Hybrid,On-site
FANTASTIC_JOBS_AI_EMPLOYMENT_TYPES=FULL_TIME,PART_TIME,CONTRACTOR,INTERN
FANTASTIC_JOBS_AI_LANGUAGES=English
# FANTASTIC_JOBS_AI_EXPERIENCE_LEVELS=0-2,2-5,5-10,10+
# FANTASTIC_JOBS_SENIORITY_FILTER=Mid-Senior level,Senior,Director
# FANTASTIC_JOBS_INDUSTRY_FILTER=
# FANTASTIC_JOBS_ORGANIZATION_SEARCH=
# FANTASTIC_JOBS_ORG_EMPLOYEES_MIN=0
# FANTASTIC_JOBS_ORG_EMPLOYEES_MAX=0

# ── LinkDAPI (linkdapi.com) — primary LinkedIn profile enrichment ────────────
# Header auth: X-linkdapi-apikey. Set the real key in .env (never commit it).
LINKDAPI_KEY=
LINKDAPI_BASE_URL=https://linkdapi.com

# ── Affinda (resume parsing) ─────────────────────────────────────────────────
AFFINDA_API_KEY=your-affinda-api-key

# ── NeverBounce (email verification) ─────────────────────────────────────────
NEVERBOUNCE_API_KEY=secret_...

# ── SendGrid (transactional email) ────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@hireloop.in
SENDGRID_FROM_NAME=Hireloop
SG_TEMPLATE_SIGNUP_CONFIRMATION=d-xxxxxxxx
SG_TEMPLATE_JOB_MATCH_ALERT=d-xxxxxxxx
SG_TEMPLATE_INTERVIEW_REMINDER=d-xxxxxxxx
SG_TEMPLATE_INTRO_STATUS=d-xxxxxxxx
SG_TEMPLATE_RECRUITER_INVITE=d-xxxxxxxx
SG_TEMPLATE_RECRUITER_INTRO_REQUEST=d-xxxxxxxx

# ── MSG91 (SMS OTP + WhatsApp transactional templates) ───────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=HLLOOP
MSG91_WHATSAPP_NUMBER=919876543210
MSG91_OTP_TEMPLATE_ID=your-msg91-sms-otp-template-id
MSG91_WHATSAPP_OTP_TEMPLATE=hireloop_otp
MSG91_JOB_MATCH_TEMPLATE=job_match_alert
MSG91_INTRO_STATUS_TEMPLATE=intro_status

# Dev only: skip OTP and auto-verify on save-phone (never enable in production)
ALLOW_PHONE_SAVE_BYPASS=false

# ── Twilio Verify (optional OTP fallback if MSG91 is missing) ────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VA...

# ── Internal service secret (app → api) ──────────────────────────────────────
SERVICE_SECRET=change-me-in-production
