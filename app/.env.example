# Hireschema — App (app/) environment variables
# Copy to .env.local and fill in real values — NEVER commit .env.local

# ── Supabase (Cloud — see SUPABASE_CLOUD_SETUP.md at repo root) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Local-only alternative: http://127.0.0.1:54321 + keys from `supabase status`

# ── API Backend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production Railway API (hireloop1 @ project 7f42f8d6-2192-4a15-912e-3d79a1869885):
# NEXT_PUBLIC_API_URL=https://hireloop1-production.up.railway.app
# Internal API secret used for server-to-server calls (Next.js Route Handlers → FastAPI)
API_SERVICE_SECRET=your-internal-service-secret

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable mock/demo data (dev + staging only)
NEXT_PUBLIC_DEMO_MODE=false

# Dev-only email/password login on /signup (for seeded test accounts)
NEXT_PUBLIC_DEV_EMAIL_LOGIN=false

# This app's public URL (OAuth redirects, metadata). Vercel sets VERCEL_URL automatically;
# set this explicitly if you use a custom domain later.
# NEXT_PUBLIC_APP_URL=https://hireloop1-app.vercel.app

# ── Marketing site URL (optional — only if web/ is deployed separately) ───────
NEXT_PUBLIC_WEB_URL=https://hireloop1-app.vercel.app
