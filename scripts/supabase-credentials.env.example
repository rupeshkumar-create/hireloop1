# Copy to supabase-credentials.env (gitignored) and fill in from Supabase Dashboard.
# Then run: python3 scripts/configure_supabase.py

# Project Settings → General → Reference ID
SUPABASE_PROJECT_REF=your-project-ref

# Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Project Settings → Database → Database password (for connection string)
SUPABASE_DB_PASSWORD=your-db-password

# Pooler region host (Dashboard → Database → Connection string → Transaction pooler)
# Example: aws-0-ap-south-1.pooler.supabase.com
SUPABASE_DB_HOST=aws-0-ap-south-1.pooler.supabase.com

# Optional — must match Supabase Auth redirect URLs for local dev
APP_URL=http://localhost:3001
API_URL=http://localhost:8000
