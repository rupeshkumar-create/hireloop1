# Hireloop — Marketing Site (web/) environment variables
# Copy to .env.local and fill in real values — NEVER commit .env.local

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── App URL (for cross-linking to the app) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Production override: https://app.hireloop.in

# ── Analytics (optional, Phase 24) ───────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
